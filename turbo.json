{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["ANDROID_HOME", "ANDROID_SDK_ROOT", "JAVA_HOME"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["lib/**", "dist/**"]
    },
    "codegen": {
      "cache": false,
      "outputs": ["nitrogen/generated/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["src/**/*.{ts,tsx}", "eslint.config.*"],
      "outputs": [".cache/eslint/.eslintcache"]
    },
    "format:check": {
      "dependsOn": ["^format:check"],
      "inputs": ["**/*.{js,cjs,mjs,ts,tsx}"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**/*.{ts,tsx}", "tsconfig.json"],
      "outputs": [".cache/tsc/**"]
    },
    "test": {
      "dependsOn": ["^test"],
      "inputs": ["src/**/*.{ts,tsx}", "jest.config.*"],
      "outputs": ["coverage/**"]
    },
    "test:cpp": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
