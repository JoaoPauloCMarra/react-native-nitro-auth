{
  "name": "example",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start -d",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "format:check": "eslint .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "install-check": "expo install --check",
    "doctor": "bunx expo-doctor@latest",
    "config:introspect": "expo config --type introspect --json > /tmp/nitro-auth-expo-config.json"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "dotenv": "^17.4.2",
    "expo": "~56.0.3",
    "expo-asset": "~56.0.13",
    "expo-build-properties": "~56.0.13",
    "expo-constants": "~56.0.14",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-nitro-auth": "workspace:*",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-nitro-storage": "^0.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~56.0.11",
    "eslint": "^10.2.1",
    "eslint-config-expo-magic": "^2.4.0"
  }
}
