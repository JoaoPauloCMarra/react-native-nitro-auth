{
  "name": "example",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "env -u NO_COLOR expo start -d",
    "ios": "env -u NO_COLOR expo run:ios",
    "android": "env -u NO_COLOR expo run:android",
    "prebuild": "env -u NO_COLOR expo prebuild",
    "prebuild:clean": "env -u NO_COLOR expo prebuild --clean",
    "format:check": "eslint .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "install-check": "env -u NO_COLOR expo install --check",
    "doctor": "bunx expo-doctor@latest",
    "config:introspect": "env -u NO_COLOR expo config --type introspect --json > /tmp/nitro-auth-expo-config.json",
    "android:assemble": "cd android && NODE_ENV=development ./gradlew --no-daemon -PreactNativeArchitectures=arm64-v8a :app:assembleDebug",
    "ios:build": "cd ios && pod install && xcodebuild -workspace NitroAuth.xcworkspace -scheme NitroAuth -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' CODE_SIGNING_ALLOWED=NO build"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "dotenv": "^17.4.2",
    "expo": "~56.0.9",
    "expo-asset": "~56.0.16",
    "expo-build-properties": "~56.0.17",
    "expo-constants": "~56.0.17",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-nitro-auth": "workspace:*",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-nitro-storage": "^0.5.6",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~56.0.11",
    "eslint": "^10.2.1",
    "eslint-config-expo-magic": "^2.4.0"
  }
}
