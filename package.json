{
  "name": "react-native-nitro-auth-monorepo",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "eslint": "^10.2.1",
    "eslint-config-expo-magic": "^2.4.0",
    "jest": "^29.7.0",
    "nitrogen": "^0.35.5",
    "react-native-builder-bob": "^0.41.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-web": "^0.21.2",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "expo": "~55.0.17",
    "expo-asset": "~55.0.16",
    "expo-constants": "~55.0.15",
    "expo-linking": "~55.0.14",
    "expo-font": "~55.0.4",
    "@expo/log-box": "~55.0.10",
    "@expo/dom-webview": "~55.0.5"
  },
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "setup": "bun scripts/setup.js",
    "publish-package": "bun scripts/publish.js",
    "publish-package:dry-run": "bun scripts/publish.js --dry-run",
    "sync-package-docs": "bun scripts/sync-package-docs.ts",
    "verify:core-versions": "bun scripts/verify-core-versions.ts",
    "build": "turbo run build",
    "codegen": "turbo run codegen",
    "clean": "turbo run clean",
    "format:check": "turbo run format:check",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:cpp": "turbo run test:cpp --filter=react-native-nitro-auth",
    "check": "turbo run lint typecheck test",
    "check:ci": "bun run verify:core-versions && bun run codegen && bun run build && bun run check && bun run test:cpp",
    "example:start": "bun run --cwd apps/example start",
    "example:ios": "bun run --cwd apps/example ios",
    "example:android": "bun run --cwd apps/example android",
    "example:prebuild": "bun run --cwd apps/example prebuild",
    "example:prebuild:clean": "bun run --cwd apps/example prebuild:clean"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
