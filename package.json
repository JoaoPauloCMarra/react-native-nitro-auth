{
  "name": "react-native-nitro-auth-monorepo",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.15",
    "eslint": "^10.4.0",
    "eslint-config-expo-magic": "^2.4.0",
    "jest": "^29.7.0",
    "nitrogen": "^0.35.7",
    "react-native-builder-bob": "^0.41.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-web": "^0.21.2",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "expo": "~56.0.4",
    "expo-asset": "~56.0.14",
    "expo-constants": "~56.0.15",
    "expo-linking": "~56.0.11",
    "expo-font": "~56.0.5",
    "@expo/log-box": "~56.0.12",
    "@expo/dom-webview": "~56.0.5"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "setup": "bun scripts/setup.js",
    "publish-package": "bun scripts/publish.js",
    "publish-package:dry-run": "bun scripts/publish.js --dry-run --skip-checks",
    "sync-package-docs": "bun scripts/sync-package-docs.ts",
    "verify:core-versions": "bun scripts/verify-core-versions.ts",
    "dev": "bun run example:start",
    "build": "turbo run build",
    "codegen": "turbo run codegen",
    "clean": "turbo run clean",
    "format:check": "turbo run format:check",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:cpp": "turbo run test:cpp --filter=react-native-nitro-auth",
    "check": "turbo run lint typecheck test",
    "check:ci": "bun run verify:core-versions && bun run codegen && bun run build && bun run check && bun run test:cpp",
    "audit:package": "bun scripts/sync-package-docs.ts && cd packages/react-native-nitro-auth && bun pm pack --dry-run",
    "example:lint": "bun run --cwd apps/example lint",
    "example:typecheck": "bun run --cwd apps/example typecheck",
    "example:check": "bun run example:lint && bun run example:typecheck && bun run example:install-check && bun run example:doctor && bun run example:config",
    "example:start": "bun run --cwd apps/example start",
    "example:ios": "bun run --cwd apps/example ios",
    "example:android": "bun run --cwd apps/example android",
    "example:prebuild": "bun run --cwd apps/example prebuild",
    "example:prebuild:clean": "bun run --cwd apps/example prebuild:clean",
    "example:android:assemble": "bun run --cwd apps/example android:assemble",
    "example:ios:build": "bun run --cwd apps/example ios:build",
    "example:smoke": "bunx maestro test maestro/smoke-tests.yaml",
    "example:install-check": "bun run --cwd apps/example install-check",
    "example:doctor": "bun run --cwd apps/example doctor",
    "example:config": "bun run --cwd apps/example config:introspect",
    "release:preflight": "bun run check:ci && bun run format:check && bun run example:check && bun run audit:package && bun run publish-package:dry-run"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
