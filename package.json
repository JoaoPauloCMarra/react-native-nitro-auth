{
  "name": "react-native-nitro-auth-monorepo",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^10.0.2",
    "eslint-config-expo-magic": "^2.0.2",
    "jest": "^29.7.0",
    "nitrogen": "^0.35.0",
    "prettier": "^3.8.1",
    "react-native-builder-bob": "^0.40.18",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.2",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-web": "^0.21.2"
  },
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "setup": "bun scripts/setup.js",
    "publish-package": "bun scripts/publish.js",
    "verify:core-versions": "bun scripts/verify-core-versions.ts",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "clean": "turbo run clean",
    "codegen": "turbo run codegen",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:cpp": "turbo run test:cpp --filter=react-native-nitro-auth",
    "start": "turbo run start --filter=example --",
    "example:ios": "turbo run ios --filter=example",
    "example:android": "turbo run android --filter=example",
    "example:prebuild": "turbo run prebuild --filter=example",
    "example:prebuild:clean": "turbo run prebuild:clean --filter=example"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
